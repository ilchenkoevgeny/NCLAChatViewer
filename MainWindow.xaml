<Window x:Class="NclaChatViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        xmlns:local="clr-namespace:NclaChatViewer"
        Title="NCLA Chat Viewer"
        Icon="Assets/AppIcon.ico"
        MinWidth="1120"
        MinHeight="720"
        Width="1280"
        Height="800"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{DynamicResource WindowBackgroundBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="34"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <local:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
        <local:LogDateAvailableConverter x:Key="LogDateAvailableConverter" />
        <local:BindingProxy x:Key="ViewModelProxy" Data="{Binding}" />

        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource ControlBackgroundHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseTitleBarButtonStyle" TargetType="Button" BasedOn="{StaticResource TitleBarButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#DC2626" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SectionToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,22,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="IconBorder"
                                    Width="18"
                                    Height="18"
                                    CornerRadius="9"
                                    Background="{DynamicResource TextBrush}"
                                    Margin="0,0,6,0">
                                <TextBlock x:Name="Arrow"
                                           Text="⌄"
                                           Foreground="{DynamicResource WindowBackgroundBrush}"
                                           FontWeight="Bold"
                                           FontSize="14"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <ContentPresenter VerticalAlignment="Center" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Arrow" Property="Text" Value="⌃" />
                                <Setter TargetName="IconBorder" Property="Background" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WrappedMessageTextBlockStyle" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextTrimming" Value="None" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="Padding" Value="0,2" />
        </Style>

        <Style x:Key="LogDateToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="9,6" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="22" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                                <Path Grid.Column="1"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Fill="{DynamicResource MutedTextBrush}"
                                      Data="M 0 0 L 4 4 L 8 0 Z" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource ControlBackgroundHoverBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LogDateCalendarStyle" TargetType="{x:Type Calendar}">
            <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="CalendarButtonStyle">
                <Setter.Value>
                    <Style TargetType="{x:Type primitives:CalendarButton}">
                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="MinWidth" Value="42" />
                        <Setter Property="MinHeight" Value="30" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type primitives:CalendarButton}">
                                    <Border x:Name="Root"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="Transparent"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="6,4"
                                            Margin="2">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource ControlBackgroundHoverBrush}" />
                                            <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource SelectionBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="CalendarDayButtonStyle">
                <Setter.Value>
                    <Style TargetType="{x:Type primitives:CalendarDayButton}">
                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="MinWidth" Value="34" />
                        <Setter Property="MinHeight" Value="28" />
                        <Setter Property="Opacity" Value="0.38" />
                        <Setter Property="IsEnabled">
                            <Setter.Value>
                                <MultiBinding Converter="{StaticResource LogDateAvailableConverter}">
                                    <Binding />
                                    <Binding Source="{StaticResource ViewModelProxy}" Path="Data.AvailableLogDates" />
                                </MultiBinding>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type primitives:CalendarDayButton}">
                                    <Border x:Name="Root"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="Transparent"
                                            BorderThickness="1"
                                            CornerRadius="7"
                                            Padding="6,4"
                                            Margin="1">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource ControlBackgroundHoverBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource SelectionBrush}" />
                                            <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                            <Setter Property="Opacity" Value="1" />
                                        </Trigger>
                                        <Trigger Property="IsToday" Value="True">
                                            <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <DataTrigger Value="True">
                                <DataTrigger.Binding>
                                    <MultiBinding Converter="{StaticResource LogDateAvailableConverter}">
                                        <Binding />
                                        <Binding Source="{StaticResource ViewModelProxy}" Path="Data.AvailableLogDates" />
                                    </MultiBinding>
                                </DataTrigger.Binding>
                                <Setter Property="Opacity" Value="1" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedChatTabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource TabBackgroundBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{Binding AccentBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="13,13,4,4"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Ellipse Grid.Column="0"
                                         Width="8"
                                         Height="8"
                                         Margin="0,0,8,0"
                                         Fill="{Binding AccentBrush}" />

                                <ContentPresenter Grid.Column="1"
                                                  x:Name="ContentSite"
                                                  ContentSource="Header"
                                                  RecognizesAccessKey="True"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource TabSelectedBackgroundBrush}" />
                                <Setter TargetName="TabBorder" Property="BorderThickness" Value="2" />
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                <Setter Property="Panel.ZIndex" Value="10" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource ControlBackgroundHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource WindowBackgroundBrush}"
            BorderBrush="{DynamicResource PanelBorderBrush}"
            BorderThickness="1">
        <Grid Background="{DynamicResource WindowBackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="34" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Background="{DynamicResource TitleBarBackgroundBrush}"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="26"
                        Height="26"
                        Margin="10,4,8,4"
                        CornerRadius="8"
                        Background="{DynamicResource ControlBackgroundBrush}"
                        BorderBrush="{DynamicResource AccentBrush}"
                        BorderThickness="1">
                    <Image Source="Assets/AppIcon.ico"
                           Width="18"
                           Height="18"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Stretch="Uniform" />
                </Border>

                <TextBlock Grid.Column="1"
                           Text="NCLA Chat Viewer"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBrush}"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="─" Style="{StaticResource TitleBarButtonStyle}" Click="MinimizeButton_Click" />
                    <Button x:Name="MaximizeRestoreButton" Content="▢" Style="{StaticResource TitleBarButtonStyle}" Click="MaximizeRestoreButton_Click" />
                    <Button Content="✕" Style="{StaticResource CloseTitleBarButtonStyle}" Click="CloseButton_Click" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Background="{DynamicResource WindowBackgroundBrush}" Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{DynamicResource PanelBackgroundBrush}"
                        CornerRadius="18"
                        Padding="14"
                        BorderBrush="{DynamicResource PanelBorderBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <WrapPanel Grid.Column="0" VerticalAlignment="Center">
                            <Button Content="Открыть файл" Command="{Binding OpenFileCommand}" />
                            <Button Content="Файл за сегодня" Command="{Binding OpenTodayFileCommand}" />
                            <Button Content="Очистить" Command="{Binding ClearCommand}" />
                            <Button Content="Открыть игру" Command="{Binding OpenGameCommand}" />
                            <Button Content="Сменить тему" Command="{Binding ToggleThemeCommand}" />
                        </WrapPanel>

                        <Border Grid.Column="1"
                                Background="{DynamicResource ControlBackgroundBrush}"
                                CornerRadius="12"
                                Padding="12,8"
                                Margin="12,0,0,0"
                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                BorderThickness="1">
                            <TextBlock Text="{Binding CurrentFilePath}"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       TextTrimming="CharacterEllipsis" />
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Background="{DynamicResource PanelBackgroundBrush}"
                        CornerRadius="18"
                        Padding="14"
                        Margin="0,12,0,12"
                        BorderBrush="{DynamicResource PanelBorderBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="142" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="Дата:" Margin="0,0,8,0" />
                                <Grid Grid.Column="1">
                                    <ToggleButton x:Name="LogDateDropDownButton"
                                                  Style="{StaticResource LogDateToggleButtonStyle}">
                                        <TextBlock Text="{Binding SelectedLogDate, StringFormat={}{0:dd.MM.yyyy}}"
                                                   Foreground="{DynamicResource TextBrush}" />
                                    </ToggleButton>

                                    <Popup x:Name="LogDatePopup"
                                           PlacementTarget="{Binding ElementName=LogDateDropDownButton}"
                                           Placement="Bottom"
                                           IsOpen="{Binding IsChecked, ElementName=LogDateDropDownButton, Mode=TwoWay}"
                                           AllowsTransparency="True"
                                           StaysOpen="False"
                                           PopupAnimation="Fade">
                                        <Border Background="{DynamicResource PanelBackgroundBrush}"
                                                BorderBrush="{DynamicResource AccentBrush}"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                Padding="10"
                                                Margin="0,6,0,0">
                                            <Calendar Style="{StaticResource LogDateCalendarStyle}"
                                                      SelectedDate="{Binding SelectedLogDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      SelectedDatesChanged="LogDateCalendar_SelectedDatesChanged" />
                                        </Border>
                                    </Popup>
                                </Grid>
                            </Grid>

                            <Grid Grid.Column="2" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="260" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="Игрок:" Margin="0,0,8,0" />
                                <ComboBox Grid.Column="1"
                                          x:Name="PlayerComboBox"
                                          IsEditable="True"
                                          IsTextSearchEnabled="False"
                                          StaysOpenOnEdit="True"
                                          MaxDropDownHeight="320"
                                          ItemsSource="{Binding Players}"
                                          SelectionChanged="PlayerComboBox_SelectionChanged"
                                          Text="{Binding SelectedPlayer, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <CheckBox Grid.Column="3"
                                          Content="по @id"
                                          Margin="0"
                                          VerticalAlignment="Center"
                                          VerticalContentAlignment="Center"
                                          IsChecked="{Binding FilterPlayerByDescriptor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          ToolTip="Фильтровать по постоянному дескриптору игрока после @, например @dopetea#9478" />
                                <CheckBox Grid.Column="5"
                                          Content="Вся история"
                                          Margin="0"
                                          IsEnabled="{Binding CanSearchWholeHistory}"
                                          VerticalAlignment="Center"
                                          VerticalContentAlignment="Center"
                                          IsChecked="{Binding SearchWholeHistory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>

                            <Grid Grid.Column="4" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="240" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="Чат:" Margin="0,0,8,0" />
                                <ComboBox Grid.Column="1"
                                          MaxDropDownHeight="320"
                                          ItemsSource="{Binding Channels}"
                                          SelectedItem="{Binding SelectedChannel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>

                            <Grid Grid.Column="6" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="Поиск:" Margin="0,0,8,0" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Поиск по содержимому сообщения" />
                            </Grid>
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,12,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <ToggleButton Content="Настройки"
                                              Style="{StaticResource SectionToggleButtonStyle}"
                                              IsChecked="{Binding IsSettingsExpanded, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <ToggleButton Content="Уведомления"
                                              Style="{StaticResource SectionToggleButtonStyle}"
                                              IsChecked="{Binding IsNotificationsExpanded, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <Border Grid.Row="1"
                                    Visibility="{Binding IsSettingsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    Margin="0,10,0,0"
                                    Padding="12"
                                    CornerRadius="14"
                                    Background="{DynamicResource PanelBackgroundAltBrush}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" MinWidth="430" />
                                        <ColumnDefinition Width="18" />
                                        <ColumnDefinition Width="*" MinWidth="430" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Row="0"
                                            Grid.Column="0"
                                            Padding="12"
                                            CornerRadius="12"
                                            Background="{DynamicResource PanelBackgroundBrush}"
                                            BorderBrush="{DynamicResource PanelBorderBrush}"
                                            BorderThickness="1">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="110" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Row="0"
                                                       Grid.Column="0"
                                                       Grid.ColumnSpan="3"
                                                       Text="Файлы логов"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextBrush}"
                                                       Margin="0,0,0,10" />

                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Каталог:" Margin="0,0,8,8" />
                                            <TextBox Grid.Row="1"
                                                     Grid.Column="1"
                                                     Text="{Binding LogsDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Margin="0,0,8,8" />
                                            <Button Grid.Row="1"
                                                    Grid.Column="2"
                                                    Content="..."
                                                    Width="42"
                                                    MinWidth="42"
                                                    Padding="0"
                                                    Margin="0,0,0,8"
                                                    ToolTip="Выбрать каталог логов"
                                                    Command="{Binding BrowseLogsDirectoryCommand}" />

                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Маска файла:" Margin="0,0,8,0" />
                                            <TextBox Grid.Row="2"
                                                     Grid.Column="1"
                                                     Grid.ColumnSpan="2"
                                                     Text="{Binding FileNamePattern, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="0"
                                            Grid.Column="2"
                                            Padding="12"
                                            CornerRadius="12"
                                            Background="{DynamicResource PanelBackgroundBrush}"
                                            BorderBrush="{DynamicResource PanelBorderBrush}"
                                            BorderThickness="1">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Row="0"
                                                       Grid.Column="0"
                                                       Grid.ColumnSpan="2"
                                                       Text="Чтение и обновление"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextBrush}"
                                                       Margin="0,0,0,10" />

                                            <TextBlock Grid.Row="1"
                                                       Grid.Column="0"
                                                       Text="Интервал, мс:"
                                                       Margin="0,0,8,12" />
                                            <TextBox Grid.Row="1"
                                                     Grid.Column="1"
                                                     Text="{Binding RefreshIntervalMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Margin="0,0,0,12" />

                                            <Grid Grid.Row="2"
                                                  Grid.Column="0"
                                                  Grid.ColumnSpan="2"
                                                  Margin="0,0,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="40" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <CheckBox Grid.Row="0"
                                                          Grid.Column="0"
                                                          Content="Открывать сегодня при старте"
                                                          IsChecked="{Binding OpenTodayFileOnStart}"
                                                          Margin="0,0,0,8"
                                                          VerticalAlignment="Center" />
                                                <CheckBox Grid.Row="1"
                                                          Grid.Column="0"
                                                          Content="Читать старое при открытии"
                                                          IsChecked="{Binding ReadExistingFileOnOpen}"
                                                          Margin="0,0,0,8"
                                                          VerticalAlignment="Center" />
                                                <CheckBox Grid.Row="2"
                                                          Grid.Column="0"
                                                          Content="Не давать ПК уснуть"
                                                          IsChecked="{Binding KeepGameActive, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          Margin="0,0,0,8"
                                                          ToolTip="Не даёт Windows усыплять систему и отключать экран, пока приложение запущено."
                                                          VerticalAlignment="Center" />
                                                <CheckBox Grid.Row="3"
                                                          Grid.Column="0"
                                                          Content="AntiAway"
                                                          IsChecked="{Binding AntiAway, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          Margin="0,0,0,8"
                                                          ToolTip="Если флаг включён, при появлении системного предупреждения AwayKickWarning будет вызван шаблонный сервис AntiAwayService."
                                                          VerticalAlignment="Center" />
                                                <CheckBox Grid.Row="0"
                                                          Grid.Column="2"
                                                          Content="Авто-переключаться на новый файл"
                                                          IsChecked="{Binding AutoSwitchToLatestTodayFile}"
                                                          Margin="0,0,0,8"
                                                          VerticalAlignment="Center" />
                                                <CheckBox Grid.Row="1"
                                                          Grid.Column="2"
                                                          Content="Оставлять сообщения при смене файла"
                                                          IsChecked="{Binding KeepMessagesWhenLogFileChanges}"
                                                          Margin="0,0,0,8"
                                                          VerticalAlignment="Center" />
                                                <CheckBox Grid.Row="2"
                                                          Grid.Column="2"
                                                          Content="Очищать при смене суток"
                                                          IsChecked="{Binding ClearMessagesWhenDateChanges}"
                                                          Margin="0,0,0,8"
                                                          VerticalAlignment="Center" />
                                                <CheckBox Grid.Row="3"
                                                          Grid.Column="2"
                                                          Content="Удалять импортированные файлы"
                                                          IsChecked="{Binding DeleteImportedLogFiles, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          Margin="0,0,0,8"
                                                          ToolTip="После переключения игры на новый лог предыдущий файл удаляется, если он уже импортирован в базу."
                                                          VerticalAlignment="Center" />
                                            </Grid>
                                        </Grid>
                                    </Border>
                                    <Grid Grid.Row="1"
                                          Grid.Column="0"
                                          Grid.ColumnSpan="3"
                                          Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="14" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Padding="12"
                                                CornerRadius="12"
                                                Background="{DynamicResource PanelBackgroundBrush}"
                                                BorderBrush="{DynamicResource PanelBorderBrush}"
                                                BorderThickness="1">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="110" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="18" />
                                                    <ColumnDefinition Width="70" />
                                                    <ColumnDefinition Width="150" />
                                                    <ColumnDefinition Width="18" />
                                                    <ColumnDefinition Width="95" />
                                                    <ColumnDefinition Width="150" />
                                                    <ColumnDefinition Width="10" />
                                                    <ColumnDefinition Width="150" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Row="0"
                                                           Grid.Column="0"
                                                           Grid.ColumnSpan="10"
                                                           Text="Таблица сообщений"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextBrush}"
                                                           Margin="0,0,0,10" />

                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Шрифт:" Margin="0,0,8,0" />
                                                <ComboBox Grid.Row="1"
                                                          Grid.Column="1"
                                                          ItemsSource="{Binding AvailableFontFamilies}"
                                                          SelectedItem="{Binding TableFontFamily, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          IsTextSearchEnabled="True"
                                                          MaxDropDownHeight="320" />

                                                <TextBlock Grid.Row="1" Grid.Column="3" Text="Размер:" Margin="0,0,8,0" />
                                                <ComboBox Grid.Row="1"
                                                          Grid.Column="4"
                                                          ItemsSource="{Binding AvailableFontSizes}"
                                                          SelectedItem="{Binding TableFontSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          MaxDropDownHeight="260" />

                                                <TextBlock Grid.Row="1" Grid.Column="6" Text="Начертание:" Margin="0,0,8,0" />
                                                <ComboBox Grid.Row="1"
                                                          Grid.Column="7"
                                                          ItemsSource="{Binding AvailableFontWeights}"
                                                          SelectedItem="{Binding TableFontWeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          MaxDropDownHeight="220" />
                                                <ComboBox Grid.Row="1"
                                                          Grid.Column="9"
                                                          ItemsSource="{Binding AvailableFontStyles}"
                                                          SelectedItem="{Binding TableFontStyle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          MaxDropDownHeight="220" />
                                            </Grid>
                                        </Border>

                                        <Border Grid.Column="2"
                                                MinWidth="210"
                                                Padding="12"
                                                CornerRadius="12"
                                                Background="{DynamicResource PanelBackgroundBrush}"
                                                BorderBrush="{DynamicResource PanelBorderBrush}"
                                                BorderThickness="1">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Row="0"
                                                           Text="Сохранение"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextBrush}"
                                                           Margin="0,0,0,10" />

                                                <Button Grid.Row="1"
                                                        Content="Сохранить настройки"
                                                        MinWidth="170"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Center"
                                                        Command="{Binding SaveSettingsCommand}" />
                                            </Grid>
                                        </Border>
                                    </Grid>

                                </Grid>
                            </Border>

                            <Border Grid.Row="2"
                                    Visibility="{Binding IsNotificationsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    Margin="0,10,0,0"
                                    Padding="12"
                                    CornerRadius="14"
                                    Background="{DynamicResource PanelBackgroundAltBrush}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0" Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <CheckBox Grid.Column="0"
                                                  Content="Включить уведомления"
                                                  IsChecked="{Binding NotificationsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button Grid.Column="2"
                                                Content="Добавить"
                                                MinWidth="110"
                                                Command="{Binding AddNotificationRuleCommand}" />
                                        <Button Grid.Column="4"
                                                Content="Открыть игру"
                                                MinWidth="120"
                                                Command="{Binding OpenGameCommand}" />
                                        <Button Grid.Column="6"
                                                Content="Проверить звук"
                                                MinWidth="130"
                                                Command="{Binding TestNotificationSoundCommand}" />
                                    </Grid>

                                    <Border Grid.Row="1"
                                            Margin="0,0,0,10"
                                            Padding="10"
                                            CornerRadius="10"
                                            Background="{DynamicResource PanelBackgroundBrush}"
                                            BorderBrush="{DynamicResource PanelBorderBrush}"
                                            BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <CheckBox Grid.Column="0"
                                                      Content="Использовать системный звук уведомления"
                                                      VerticalAlignment="Center"
                                                      IsChecked="{Binding UseSystemNotificationSound, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                            <TextBox Grid.Column="2"
                                                     Text="{Binding NotificationSoundFilePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     IsEnabled="{Binding IsCustomNotificationSoundEnabled}"
                                                     ToolTip="WAV-файл для пользовательского звука уведомления" />
                                            <Button Grid.Column="4"
                                                    Content="..."
                                                    Width="42"
                                                    MinWidth="42"
                                                    Padding="0"
                                                    IsEnabled="{Binding IsCustomNotificationSoundEnabled}"
                                                    ToolTip="Выбрать WAV-файл"
                                                    Command="{Binding BrowseNotificationSoundFileCommand}" />
                                        </Grid>
                                    </Border>

                                    <TextBlock Grid.Row="2"
                                               Text="Правила срабатывают только для новых сообщений после открытия файла. Для личных сообщений чат и фраза не требуются."
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               Margin="0,0,0,8" />

                                    <Border Grid.Row="3"
                                            MinHeight="160"
                                            MaxHeight="300"
                                            Padding="10"
                                            CornerRadius="12"
                                            Background="{DynamicResource PanelBackgroundBrush}"
                                            BorderBrush="{DynamicResource PanelBorderBrush}"
                                            BorderThickness="1">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled">
                                            <ItemsControl ItemsSource="{Binding NotificationRules}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,0,0,8"
                                                                Padding="10"
                                                                CornerRadius="10"
                                                                Background="{DynamicResource ControlBackgroundBrush}"
                                                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                                                BorderThickness="1">
                                                            <Grid VerticalAlignment="Top">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="70" />
                                                                    <ColumnDefinition Width="16" />
                                                                    <ColumnDefinition Width="220" />
                                                                    <ColumnDefinition Width="16" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="16" />
                                                                    <ColumnDefinition Width="90" />
                                                                    <ColumnDefinition Width="16" />
                                                                    <ColumnDefinition Width="90" />
                                                                    <ColumnDefinition Width="16" />
                                                                    <ColumnDefinition Width="110" />
                                                                    <ColumnDefinition Width="16" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>

                                                                <!--
                                                                    Во всех колонках есть одинаковая верхняя строка-подпись и одинаковая нижняя строка-контрол.
                                                                    Даже если подпись визуально пустая, она сохраняет одинаковую высоту,
                                                                    поэтому чекбоксы, поля и кнопка стоят на одной горизонтальной линии.
                                                                -->
                                                                <Grid Grid.Column="0">
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="18" />
                                                                        <RowDefinition Height="32" />
                                                                    </Grid.RowDefinitions>

                                                                    <TextBlock Grid.Row="0"
                                                                               Text=" "
                                                                               Foreground="{DynamicResource MutedTextBrush}" />
                                                                    <CheckBox Grid.Row="1"
                                                                              Content="Вкл."
                                                                              VerticalAlignment="Center"
                                                                              VerticalContentAlignment="Center"
                                                                              IsChecked="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                                </Grid>

                                                                <Grid Grid.Column="2">
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="18" />
                                                                        <RowDefinition Height="32" />
                                                                    </Grid.RowDefinitions>

                                                                    <TextBlock Grid.Row="0"
                                                                               Text="Условие"
                                                                               Foreground="{DynamicResource MutedTextBrush}"
                                                                               VerticalAlignment="Top" />
                                                                    <ComboBox Grid.Row="1"
                                                                              ItemsSource="{Binding DataContext.NotificationTriggerModes, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                              SelectedItem="{Binding TriggerKind, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                              Height="30"
                                                                              VerticalAlignment="Center"
                                                                              VerticalContentAlignment="Center" />
                                                                </Grid>

                                                                <Grid Grid.Column="4"
                                                                      Visibility="{Binding IsTextContains, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="18" />
                                                                        <RowDefinition Height="32" />
                                                                    </Grid.RowDefinitions>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="230" />
                                                                        <ColumnDefinition Width="16" />
                                                                        <ColumnDefinition Width="*" />
                                                                    </Grid.ColumnDefinitions>

                                                                    <TextBlock Grid.Row="0"
                                                                               Grid.Column="0"
                                                                               Text="Чат"
                                                                               Foreground="{DynamicResource MutedTextBrush}"
                                                                               VerticalAlignment="Top" />
                                                                    <ComboBox Grid.Row="1"
                                                                              Grid.Column="0"
                                                                              ItemsSource="{Binding DataContext.NotificationChannels, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                              DisplayMemberPath="DisplayName"
                                                                              SelectedValuePath="Value"
                                                                              SelectedValue="{Binding ChatFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                              IsTextSearchEnabled="True"
                                                                              TextSearch.TextPath="DisplayName"
                                                                              Height="30"
                                                                              MaxDropDownHeight="260"
                                                                              VerticalAlignment="Center"
                                                                              VerticalContentAlignment="Center" />

                                                                    <TextBlock Grid.Row="0"
                                                                               Grid.Column="2"
                                                                               Text="Фраза"
                                                                               Foreground="{DynamicResource MutedTextBrush}"
                                                                               VerticalAlignment="Top" />
                                                                    <TextBox Grid.Row="1"
                                                                             Grid.Column="2"
                                                                             Text="{Binding Phrase, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                             Height="30"
                                                                             VerticalAlignment="Center"
                                                                             VerticalContentAlignment="Center"
                                                                             ToolTip="Фрагмент текста сообщения, например ОБМ" />
                                                                </Grid>

                                                                <Grid Grid.Column="4"
                                                                      Visibility="{Binding IsPrivateMessage, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="18" />
                                                                        <RowDefinition Height="32" />
                                                                    </Grid.RowDefinitions>

                                                                    <TextBlock Grid.Row="0"
                                                                               Text=" "
                                                                               Foreground="{DynamicResource MutedTextBrush}" />
                                                                    <Border Grid.Row="1"
                                                                            Height="30"
                                                                            VerticalAlignment="Center"
                                                                            Padding="12,0"
                                                                            CornerRadius="8"
                                                                            Background="{DynamicResource PanelBackgroundAltBrush}"
                                                                            BorderBrush="{DynamicResource ControlBorderBrush}"
                                                                            BorderThickness="1">
                                                                        <TextBlock Text="Личное сообщение: чат и фраза не используются"
                                                                                   Foreground="{DynamicResource MutedTextBrush}"
                                                                                   VerticalAlignment="Center"
                                                                                   TextWrapping="NoWrap"
                                                                                   TextTrimming="CharacterEllipsis" />
                                                                    </Border>
                                                                </Grid>

                                                                <Grid Grid.Column="4"
                                                                      Visibility="{Binding IsPlayerDescriptor, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="18" />
                                                                        <RowDefinition Height="32" />
                                                                    </Grid.RowDefinitions>

                                                                    <TextBlock Grid.Row="0"
                                                                               Text="Дескриптор"
                                                                               Foreground="{DynamicResource MutedTextBrush}"
                                                                               VerticalAlignment="Top" />
                                                                    <TextBox Grid.Row="1"
                                                                             Text="{Binding Phrase, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                             Height="30"
                                                                             VerticalAlignment="Center"
                                                                             VerticalContentAlignment="Center"
                                                                             ToolTip="Дескриптор игрока, например @dopetea#9478. Можно вставить полный ник, дескриптор будет взят автоматически." />
                                                                </Grid>

                                                                <Grid Grid.Column="6">
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="18" />
                                                                        <RowDefinition Height="32" />
                                                                    </Grid.RowDefinitions>

                                                                    <TextBlock Grid.Row="0"
                                                                               Text=" "
                                                                               Foreground="{DynamicResource MutedTextBrush}" />
                                                                    <CheckBox Grid.Row="1"
                                                                              Content="Звук"
                                                                              VerticalAlignment="Center"
                                                                              VerticalContentAlignment="Center"
                                                                              IsChecked="{Binding PlaySound, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                                </Grid>

                                                                <Grid Grid.Column="8">
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="18" />
                                                                        <RowDefinition Height="32" />
                                                                    </Grid.RowDefinitions>

                                                                    <TextBlock Grid.Row="0"
                                                                               Text=" "
                                                                               Foreground="{DynamicResource MutedTextBrush}" />
                                                                    <CheckBox Grid.Row="1"
                                                                              Content="Окно"
                                                                              ToolTip="Показывать всплывающее окно"
                                                                              VerticalAlignment="Center"
                                                                              VerticalContentAlignment="Center"
                                                                              IsChecked="{Binding ShowPopup, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                                </Grid>

                                                                <Grid Grid.Column="10">
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="18" />
                                                                        <RowDefinition Height="32" />
                                                                    </Grid.RowDefinitions>

                                                                    <TextBlock Grid.Row="0"
                                                                               Text=" "
                                                                               Foreground="{DynamicResource MutedTextBrush}" />
                                                                    <CheckBox Grid.Row="1"
                                                                              Content="Исчез."
                                                                              ToolTip="Через 10 секунд плавно скрывать всплывающее окно"
                                                                              VerticalAlignment="Center"
                                                                              VerticalContentAlignment="Center"
                                                                              IsEnabled="{Binding CanUseDisappearingPopup}"
                                                                              IsChecked="{Binding DisappearingPopup, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                                </Grid>

                                                                <Grid Grid.Column="12">
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="18" />
                                                                        <RowDefinition Height="32" />
                                                                    </Grid.RowDefinitions>

                                                                    <TextBlock Grid.Row="0"
                                                                               Text=" "
                                                                               Foreground="{DynamicResource MutedTextBrush}" />
                                                                    <Button Grid.Row="1"
                                                                            Content="Удалить"
                                                                            MinWidth="86"
                                                                            Height="30"
                                                                            Padding="10,4"
                                                                            VerticalAlignment="Center"
                                                                            Command="{Binding DataContext.RemoveNotificationRuleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                            CommandParameter="{Binding}" />
                                                                </Grid>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Background="{DynamicResource PanelBackgroundBrush}"
                        CornerRadius="18"
                        Padding="10"
                        BorderBrush="{DynamicResource PanelBorderBrush}"
                        BorderThickness="1">
                    <TabControl ItemsSource="{Binding VisibleTabs}"
                                SelectedItem="{Binding SelectedTab, Mode=TwoWay}"
                                ItemContainerStyle="{StaticResource RoundedChatTabItemStyle}">
                        <TabControl.Resources>
                            <Style TargetType="TabPanel">
                                <Setter Property="Margin" Value="0,0,0,4" />
                            </Style>
                        </TabControl.Resources>

                        <TabControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding DisplayName}" />
                                    <TextBlock Text="  " />
                                    <TextBlock Text="{Binding FilteredCount}" Foreground="{DynamicResource MutedTextBrush}" />
                                </StackPanel>
                            </DataTemplate>
                        </TabControl.ItemTemplate>

                        <TabControl.ContentTemplate>
                            <DataTemplate>
                                <Border CornerRadius="12"
                                        BorderBrush="{DynamicResource ControlBorderBrush}"
                                        BorderThickness="1"
                                        Background="{DynamicResource PanelBackgroundAltBrush}">
                                    <Grid>
                                        <!--
                                            Обычные вкладки.
                                            Колонок "Напр." и "Кому" здесь нет физически, поэтому они не занимают место
                                            и не остаются пустыми на системных, локальных, торговых и других чатах.
                                        -->
                                        <DataGrid ItemsSource="{Binding FilteredMessages}"
                                                  Visibility="{Binding IsPrivateTab, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                                  PreviewMouseRightButtonDown="ChatDataGrid_PreviewMouseRightButtonDown"
                                                  ContextMenuOpening="ChatDataGrid_ContextMenuOpening"
                                                  FontFamily="{Binding DataContext.TableFontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  FontSize="{Binding DataContext.TableFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  FontWeight="{Binding DataContext.TableFontWeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  FontStyle="{Binding DataContext.TableFontStyle, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  AutoGenerateColumns="False"
                                                  IsReadOnly="True"
                                                  CanUserAddRows="False"
                                                  CanUserDeleteRows="False"
                                                  EnableRowVirtualization="True"
                                                  EnableColumnVirtualization="True"
                                                  VirtualizingPanel.IsVirtualizing="True"
                                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                                  ScrollViewer.CanContentScroll="True"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                  AlternationCount="2"
                                                  ColumnWidth="SizeToHeader">
                                            <DataGrid.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Копировать текст сообщения"
                                                              Click="CopyMessageTextMenuItem_Click" />
                                                </ContextMenu>
                                            </DataGrid.ContextMenu>
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Время" Binding="{Binding Time, StringFormat=dd.MM.yyyy HH:mm:ss}" Width="170" />
                                                <DataGridTextColumn Header="Игрок" Binding="{Binding Player}" Width="220" />
                                                <DataGridTextColumn Header="Чат" Binding="{Binding ChatName}" Width="140" />
                                                <DataGridTextColumn Header="Тип" Binding="{Binding DisplayChatType}" Width="150" />
                                                <DataGridTemplateColumn Header="Сообщение" Width="*" MinWidth="320">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Message}"
                                                                       TextWrapping="Wrap"
                                                                       TextTrimming="None"
                                                                       VerticalAlignment="Top"
                                                                       Padding="0,2" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>

                                        <!--
                                            Вкладка личных сообщений.
                                            Здесь нужны дополнительные колонки: направление и адресат.
                                        -->
                                        <DataGrid ItemsSource="{Binding FilteredMessages}"
                                                  Visibility="{Binding IsPrivateTab, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                  PreviewMouseRightButtonDown="ChatDataGrid_PreviewMouseRightButtonDown"
                                                  ContextMenuOpening="ChatDataGrid_ContextMenuOpening"
                                                  FontFamily="{Binding DataContext.TableFontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  FontSize="{Binding DataContext.TableFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  FontWeight="{Binding DataContext.TableFontWeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  FontStyle="{Binding DataContext.TableFontStyle, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  AutoGenerateColumns="False"
                                                  IsReadOnly="True"
                                                  CanUserAddRows="False"
                                                  CanUserDeleteRows="False"
                                                  EnableRowVirtualization="True"
                                                  EnableColumnVirtualization="True"
                                                  VirtualizingPanel.IsVirtualizing="True"
                                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                                  ScrollViewer.CanContentScroll="True"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                  AlternationCount="2"
                                                  ColumnWidth="SizeToHeader">
                                            <DataGrid.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Копировать текст сообщения"
                                                              Click="CopyMessageTextMenuItem_Click" />
                                                    <MenuItem Header="Показать диалог"
                                                              Tag="ShowPrivateDialog"
                                                              Click="ShowPrivateDialogMenuItem_Click" />
                                                </ContextMenu>
                                            </DataGrid.ContextMenu>
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Время" Binding="{Binding Time, StringFormat=HH:mm:ss}" Width="84" />
                                                <DataGridTextColumn Header="Игрок" Binding="{Binding Player}" Width="220" />
                                                <DataGridTextColumn Header="Напр." Binding="{Binding PrivateDirection}" Width="105" />
                                                <DataGridTextColumn Header="Кому" Binding="{Binding DisplayTarget}" Width="220" />
                                                <DataGridTextColumn Header="Чат" Binding="{Binding ChatName}" Width="140" />
                                                <DataGridTextColumn Header="Тип" Binding="{Binding DisplayChatType}" Width="150" />
                                                <DataGridTemplateColumn Header="Сообщение" Width="*" MinWidth="320">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Message}"
                                                                       TextWrapping="Wrap"
                                                                       TextTrimming="None"
                                                                       VerticalAlignment="Top"
                                                                       Padding="0,2" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </TabControl.ContentTemplate>
                    </TabControl>
                </Border>

                <Border Grid.Row="3"
                        Background="{DynamicResource PanelBackgroundBrush}"
                        CornerRadius="14"
                        Padding="11"
                        Margin="0,12,0,0"
                        BorderBrush="{DynamicResource PanelBorderBrush}"
                        BorderThickness="1">
                    <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource MutedTextBrush}" />
                </Border>
            </Grid>

            <Grid Grid.Row="1"
                  Background="#AA020617"
                  Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border Width="360"
                        Padding="24"
                        CornerRadius="16"
                        Background="{DynamicResource PanelBackgroundBrush}"
                        BorderBrush="{DynamicResource AccentBrush}"
                        BorderThickness="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="⟳"
                                   FontSize="44"
                                   Foreground="{DynamicResource AccentBrush}"
                                   HorizontalAlignment="Center"
                                   RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform>
                                <RotateTransform />
                            </TextBlock.RenderTransform>
                            <TextBlock.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="(TextBlock.RenderTransform).(RotateTransform.Angle)"
                                                             From="0"
                                                             To="360"
                                                             Duration="0:0:1" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </TextBlock.Triggers>
                        </TextBlock>

                        <TextBlock Text="{Binding LoadingTitle}"
                                   Margin="0,10,0,8"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}"
                                   HorizontalAlignment="Center" />

                        <TextBlock Text="{Binding LoadingProgressText}"
                                   Margin="0,0,0,4"
                                   FontSize="46"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}"
                                   HorizontalAlignment="Center" />

                        <TextBlock Text="{Binding LoadingText}"
                                   Margin="0,0,0,12"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   HorizontalAlignment="Center" />

                        <ProgressBar Minimum="0"
                                     Maximum="100"
                                     Height="14"
                                     Value="{Binding LoadingProgress, Mode=OneWay}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
