<Window x:Class="NclaChatViewer.Views.PrivateDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="{Binding Title}"
        Width="760"
        Height="620"
        MinWidth="560"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        Background="Transparent"
        AllowsTransparency="True">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="8"
                            CornerRadius="18"
                            GlassFrameThickness="0" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <DataTemplate x:Key="DialogColorOptionTemplate">
            <StackPanel Orientation="Horizontal">
                <Border Width="14"
                        Height="14"
                        CornerRadius="4"
                        BorderBrush="{DynamicResource ControlBorderBrush}"
                        BorderThickness="1"
                        Background="{Binding}"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center" />
                <TextBlock Text="{Binding}"
                           Foreground="{DynamicResource TextBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </DataTemplate>

        <Style x:Key="DialogSettingsToggleStyle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource ControlBackgroundHoverBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SelectionBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource PanelBackgroundBrush}"
            BorderBrush="{DynamicResource AccentBrush}"
            BorderThickness="1"
            CornerRadius="18"
            Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Margin="0,0,0,12"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="36"
                        Height="36"
                        CornerRadius="11"
                        Background="{DynamicResource ControlBackgroundBrush}"
                        BorderBrush="{DynamicResource AccentBrush}"
                        BorderThickness="1"
                        Margin="0,0,10,0">
                    <Image Source="/Assets/AppIcon.ico"
                           Width="23"
                           Height="23"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Stretch="Uniform" />
                </Border>

                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding Title}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding Subtitle}"
                               Margin="0,2,0,0"
                               FontSize="12"
                               Foreground="{DynamicResource MutedTextBrush}"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <Button Grid.Column="2"
                        Content="x"
                        Width="34"
                        Height="30"
                        Padding="0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Click="CloseButton_Click" />
            </Grid>

            <Border Grid.Row="1"
                    Background="{DynamicResource ControlBackgroundBrush}"
                    BorderBrush="{DynamicResource ControlBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="10,8"
                    Margin="0,0,0,12">
                <TextBlock Text="{Binding RangeText}"
                           Foreground="{DynamicResource MutedTextBrush}"
                           TextTrimming="CharacterEllipsis" />
            </Border>

            <Border Grid.Row="2"
                    Background="{DynamicResource PanelBackgroundAltBrush}"
                    BorderBrush="{DynamicResource ControlBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="10">
                <ListBox x:Name="MessagesList"
                         ItemsSource="{Binding Messages}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Focusable" Value="False" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border x:Name="Bubble"
                                        Grid.Column="0"
                                        HorizontalAlignment="Left"
                                        MaxWidth="430"
                                        Background="{DynamicResource ControlBackgroundBrush}"
                                        BorderBrush="{DynamicResource ControlBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="11,8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Header}"
                                                   FontSize="{Binding DataContext.SenderFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   FontFamily="{Binding DataContext.SenderFontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   FontWeight="{Binding DataContext.SenderFontWeightValue, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   FontStyle="{Binding DataContext.SenderFontStyleValue, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   Foreground="{Binding DataContext.SenderColorBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Message}"
                                                   Margin="0,5,0,6"
                                                   FontSize="{Binding DataContext.MessageFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   FontFamily="{Binding DataContext.MessageFontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   FontWeight="{Binding DataContext.MessageFontWeightValue, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   FontStyle="{Binding DataContext.MessageFontStyleValue, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   Foreground="{Binding DataContext.MessageColorBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding TimeText}"
                                                   HorizontalAlignment="Right"
                                                   FontSize="11"
                                                   Visibility="{Binding DataContext.TimeVisibility, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   Foreground="{DynamicResource MutedTextBrush}" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsOutgoing}" Value="True">
                                    <Setter TargetName="Bubble" Property="Grid.Column" Value="1" />
                                    <Setter TargetName="Bubble" Property="HorizontalAlignment" Value="Right" />
                                    <Setter TargetName="Bubble" Property="Background" Value="{DynamicResource SelectionBrush}" />
                                    <Setter TargetName="Bubble" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <Grid Grid.Row="3"
                  Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <ToggleButton x:Name="DialogSettingsButton"
                                  Width="34"
                                  Height="34"
                                  Padding="0"
                                  Content="⚙"
                                  FontSize="17"
                                  Style="{StaticResource DialogSettingsToggleStyle}"
                                  ToolTip="Настройки отображения диалога" />

                    <Popup PlacementTarget="{Binding ElementName=DialogSettingsButton}"
                           Placement="Top"
                           IsOpen="{Binding IsChecked, ElementName=DialogSettingsButton, Mode=TwoWay}"
                           AllowsTransparency="True"
                           StaysOpen="False"
                           PopupAnimation="Fade">
                        <Border Background="{DynamicResource PanelBackgroundBrush}"
                                BorderBrush="{DynamicResource AccentBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="14"
                                Margin="0,0,0,8"
                                MinWidth="640">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Text="Настройки диалога"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"
                                           Margin="0,0,0,12" />

                                <Grid Grid.Row="1" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="112" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="62" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="132" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="132" />
                                        <ColumnDefinition Width="30" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="Сообщение"
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               VerticalAlignment="Center" />
                                    <ComboBox Grid.Column="1"
                                              IsEditable="True"
                                              IsTextSearchEnabled="True"
                                              ItemsSource="{Binding AvailableFontFamilies}"
                                              Text="{Binding MessageFontFamily, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <ComboBox Grid.Column="3"
                                              ItemsSource="{Binding AvailableFontSizes}"
                                              SelectedItem="{Binding MessageFontSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <ComboBox Grid.Column="5"
                                              ItemsSource="{Binding FontAppearanceOptions}"
                                              DisplayMemberPath="DisplayName"
                                              SelectedValuePath="Value"
                                              SelectedValue="{Binding MessageFontAppearance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <ComboBox Grid.Column="7"
                                              IsEditable="True"
                                              IsTextSearchEnabled="False"
                                              ItemsSource="{Binding ColorOptions}"
                                              ItemTemplate="{StaticResource DialogColorOptionTemplate}"
                                              Text="{Binding MessageColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <Border Grid.Column="8"
                                            Width="20"
                                            Height="20"
                                            CornerRadius="5"
                                            BorderBrush="{DynamicResource ControlBorderBrush}"
                                            BorderThickness="1"
                                            Background="{Binding MessageColorBrush}"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center" />
                                </Grid>

                                <Grid Grid.Row="2" Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="112" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="62" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="132" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="132" />
                                        <ColumnDefinition Width="30" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="Отправитель"
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               VerticalAlignment="Center" />
                                    <ComboBox Grid.Column="1"
                                              IsEditable="True"
                                              IsTextSearchEnabled="True"
                                              ItemsSource="{Binding AvailableFontFamilies}"
                                              Text="{Binding SenderFontFamily, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <ComboBox Grid.Column="3"
                                              ItemsSource="{Binding AvailableFontSizes}"
                                              SelectedItem="{Binding SenderFontSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <ComboBox Grid.Column="5"
                                              ItemsSource="{Binding FontAppearanceOptions}"
                                              DisplayMemberPath="DisplayName"
                                              SelectedValuePath="Value"
                                              SelectedValue="{Binding SenderFontAppearance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <ComboBox Grid.Column="7"
                                              IsEditable="True"
                                              IsTextSearchEnabled="False"
                                              ItemsSource="{Binding ColorOptions}"
                                              ItemTemplate="{StaticResource DialogColorOptionTemplate}"
                                              Text="{Binding SenderColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <Border Grid.Column="8"
                                            Width="20"
                                            Height="20"
                                            CornerRadius="5"
                                            BorderBrush="{DynamicResource ControlBorderBrush}"
                                            BorderThickness="1"
                                            Background="{Binding SenderColorBrush}"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center" />
                                </Grid>

                                <CheckBox Grid.Row="3"
                                          Content="Показывать время сообщения"
                                          IsChecked="{Binding ShowMessageTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Margin="0,0,0,8" />

                                <CheckBox Grid.Row="4"
                                          Content="Показывать только ник без дескриптора"
                                          IsChecked="{Binding ShowShortPlayerName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Margin="0" />
                            </Grid>
                        </Border>
                    </Popup>
                </Grid>

                <Button Grid.Column="2"
                        Content="Закрыть"
                        MinWidth="96"
                        Click="CloseButton_Click" />
            </Grid>
        </Grid>
    </Border>
</Window>
