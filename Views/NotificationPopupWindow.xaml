<Window x:Class="NclaChatViewer.Views.NotificationPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Уведомление"
        Width="460"
        SizeToContent="Height"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="Transparent"
        AllowsTransparency="True"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Border Background="{DynamicResource PanelBackgroundBrush}"
            BorderBrush="{DynamicResource AccentBrush}"
            BorderThickness="1"
            CornerRadius="16"
            Padding="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="32"
                        Height="32"
                        CornerRadius="10"
                        Background="{DynamicResource ControlBackgroundBrush}"
                        BorderBrush="{DynamicResource AccentBrush}"
                        BorderThickness="1"
                        Margin="0,0,10,0">
                    <Image Source="../Assets/AppIcon.ico"
                           Width="22"
                           Height="22"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Stretch="Uniform" />
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Title}"
                               Foreground="{DynamicResource TextBrush}"
                               FontWeight="SemiBold"
                               FontSize="15" />
                    <TextBlock Text="{Binding Time}"
                               Foreground="{DynamicResource MutedTextBrush}"
                               FontSize="12" />
                </StackPanel>

                <Button Grid.Column="2"
                        Content="✕"
                        Width="34"
                        Height="30"
                        Padding="0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Click="CloseButton_Click" />
            </Grid>

            <Grid Grid.Row="1" Margin="0,0,0,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="74" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="От:" Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,8,4" />
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding From}" Foreground="{DynamicResource TextBrush}" TextTrimming="CharacterEllipsis" Margin="0,0,0,4" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Кому:" Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,8,4" />
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding To}" Foreground="{DynamicResource TextBrush}" TextTrimming="CharacterEllipsis" Margin="0,0,0,4" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Чат:" Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,8,4" />
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Chat}" Foreground="{DynamicResource TextBrush}" TextTrimming="CharacterEllipsis" Margin="0,0,0,4" />

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Тип:" Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,8,0" />
                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Type}" Foreground="{DynamicResource TextBrush}" TextTrimming="CharacterEllipsis" />
            </Grid>

            <Border Grid.Row="2"
                    Background="{DynamicResource ControlBackgroundBrush}"
                    BorderBrush="{DynamicResource ControlBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="12"
                    Margin="0,0,0,12">
                <TextBlock Text="{Binding Message}"
                           Foreground="{DynamicResource TextBrush}"
                           TextWrapping="Wrap"
                           MaxHeight="180" />
            </Border>

            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Нажмите «Открыть игру», чтобы перейти к клиенту."
                           Foreground="{DynamicResource MutedTextBrush}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />

                <Button Grid.Column="1"
                        Content="Открыть игру"
                        MinWidth="120"
                        Click="OpenGameButton_Click" />

                <Button Grid.Column="3"
                        Content="Закрыть"
                        MinWidth="90"
                        Click="CloseButton_Click" />
            </Grid>
        </Grid>
    </Border>
</Window>
