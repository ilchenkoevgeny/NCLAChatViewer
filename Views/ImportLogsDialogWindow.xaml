<Window x:Class="NclaChatViewer.Views.ImportLogsDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NCLA Chat Viewer"
        Width="460"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="Transparent"
        AllowsTransparency="True">
    <Window.Resources>
        <Style x:Key="DialogCloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource ControlBackgroundHoverBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource PanelBackgroundBrush}"
            BorderBrush="{DynamicResource AccentBrush}"
            BorderThickness="1"
            CornerRadius="18"
            Padding="18">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="34"
                        Height="34"
                        CornerRadius="10"
                        Background="{DynamicResource ControlBackgroundBrush}"
                        BorderBrush="{DynamicResource AccentBrush}"
                        BorderThickness="1"
                        Margin="0,0,10,0">
                    <Image Source="/Assets/AppIcon.ico"
                           Width="22"
                           Height="22"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Stretch="Uniform" />
                </Border>

                <TextBlock x:Name="TitleText"
                           Grid.Column="1"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBrush}" />

                <Button Grid.Column="2"
                        Content="x"
                        Style="{StaticResource DialogCloseButtonStyle}"
                        Click="SecondaryButton_Click" />
            </Grid>

            <Grid Grid.Row="1"
                  Margin="0,18,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="42"
                        Height="42"
                        CornerRadius="21"
                        Background="{DynamicResource ControlBackgroundBrush}"
                        BorderBrush="{DynamicResource AccentBrush}"
                        BorderThickness="1"
                        Margin="0,0,14,0"
                        VerticalAlignment="Top">
                    <TextBlock x:Name="IconText"
                               Text="?"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>

                <TextBlock x:Name="MessageText"
                           Grid.Column="1"
                           TextWrapping="Wrap"
                           LineHeight="19"
                           Foreground="{DynamicResource TextBrush}"
                           VerticalAlignment="Top" />
            </Grid>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="PrimaryButton"
                        MinWidth="126"
                        Click="PrimaryButton_Click" />
                <Button x:Name="SecondaryButton"
                        MinWidth="92"
                        Click="SecondaryButton_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
