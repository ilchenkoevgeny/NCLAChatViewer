{
  "LogsDirectory": "Samples",
  "FileNamePattern": "chat_{0:yyyy-MM-dd}_*.log",
  "RefreshIntervalMs": 2000,
  "OpenTodayFileOnStart": true,
  "ReadExistingFileOnOpen": true,
  "IgnoreCombatChats": true,
  "AutoSwitchToLatestTodayFile": true,
  "KeepMessagesWhenLogFileChanges": true,
  "ClearMessagesWhenDateChanges": true,
  "Theme": "Dark",
  "TableFontFamily": "Segoe UI",
  "TableFontSize": 13,
  "TableFontWeight": "Normal",
  "TableFontStyle": "Normal",
  "KeepGameActive": false,
  "AntiAway": false,
  "KeepGameActiveIntervalMinutes": 10,
  "NotificationsEnabled": false,
  "UseSystemNotificationSound": true,
  "NotificationSoundFilePath": "",
  "NotificationRules": []
}